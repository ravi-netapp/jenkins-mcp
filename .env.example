JENKINS_URL=https://jenkins.example.com
JENKINS_USERNAME=your-username
JENKINS_API_TOKEN=your-api-token
# Set to true only if you need run_script_console (dangerous).
JENKINS_ALLOW_SCRIPT_CONSOLE=false
